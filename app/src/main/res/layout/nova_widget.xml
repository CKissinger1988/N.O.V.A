<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. Cyber-Offensive Layout (N.O.V.A SOC) -->
    <RelativeLayout
        android:id="@+id/widget_nova_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_background_nova"
        android:padding="12dp"
        android:visibility="visible">

        <!-- Header -->
        <ImageView
            android:id="@+id/widget_nova_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_launcher_nova"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/widget_nova_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="N.O.V.A. SUPREME"
            android:textColor="#00D1FF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_toEndOf="@id/widget_nova_logo"
            android:layout_marginStart="8dp"
            android:layout_alignTop="@id/widget_nova_logo" />

        <TextView
            android:id="@+id/widget_nova_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tactical Command System v2"
            android:textColor="#0088FF"
            android:textSize="9sp"
            android:layout_toEndOf="@id/widget_nova_logo"
            android:layout_marginStart="8dp"
            android:layout_below="@id/widget_nova_title" />

        <!-- Telemetry Data -->
        <LinearLayout
            android:id="@+id/widget_nova_telemetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_below="@id/widget_nova_logo"
            android:layout_alignParentStart="true"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/widget_cpu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU: --%"
                android:textColor="#00FFCC"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/widget_ram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RAM: --%"
                android:textColor="#00FFCC"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/widget_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BATT: --%"
                android:textColor="#00FFCC"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Status Panel -->
        <LinearLayout
            android:id="@+id/widget_nova_status_panel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/widget_nova_telemetry"
            android:gravity="end">

            <TextView
                android:id="@+id/widget_node_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NODES: 0"
                android:textColor="#0088FF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/widget_threat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THREAT: LOW"
                android:textColor="#00FFCC"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/widget_c2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C2: OFFLINE"
                android:textColor="#0088FF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Gemini AI Feed Section -->
        <LinearLayout
            android:id="@+id/widget_gemini_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/widget_nova_telemetry"
            android:layout_marginTop="6dp"
            android:background="#1100D1FF"
            android:padding="6dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> GEMINI UPLINK ACTIVE"
                android:textColor="#00D1FF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/widget_ai_advisory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Awaiting reconnaissance data for tactical modeling..."
                android:textColor="#E0F7FF"
                android:textSize="10sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Action Buttons at bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentBottom="true"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/widget_btn_scan"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="RECON"
                android:textColor="#00D1FF"
                android:background="#2200D1FF"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_btn_ai"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="GEMINI"
                android:textColor="#00FFCC"
                android:background="#2200FFCC"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_btn_omega"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="OMEGA"
                android:textColor="#FF3366"
                android:background="#22FF3366"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>


    </RelativeLayout>


    <!-- 2. Disguised Cover Layout (Master Baker) -->
    <RelativeLayout
        android:id="@+id/widget_baking_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_background_baking"
        android:padding="12dp"
        android:visibility="gone">

        <!-- Header -->
        <ImageView
            android:id="@+id/widget_baking_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_launcher_baking"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true" />

        <TextView
            android:id="@+id/widget_baking_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Master Baker"
            android:textColor="#4A3728"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_toEndOf="@id/widget_baking_logo"
            android:layout_marginStart="8dp"
            android:layout_alignTop="@id/widget_baking_logo" />

        <TextView
            android:id="@+id/widget_baking_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kitchen Assistant &amp; Timers"
            android:textColor="#8B5E3C"
            android:textSize="9sp"
            android:layout_toEndOf="@id/widget_baking_logo"
            android:layout_marginStart="8dp"
            android:layout_below="@id/widget_baking_title" />

        <!-- Recipe/Oven Details -->
        <LinearLayout
            android:id="@+id/widget_baking_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_below="@id/widget_baking_logo"
            android:layout_alignParentStart="true"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/widget_recipe_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recipe: Sourdough Bread"
                android:textColor="#4A3728"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/widget_oven_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oven: Preheating (180°C)"
                android:textColor="#4A3728"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- AI Chef Feed Section -->
        <LinearLayout
            android:id="@+id/widget_chef_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/widget_baking_details"
            android:layout_marginTop="6dp"
            android:background="#114A3728"
            android:padding="6dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> AI CHEF ADVISORY"
                android:textColor="#4A3728"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_chef_advisory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Optimal hydration detected for current ambient temperature."
                android:textColor="#4A3728"
                android:textSize="10sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Status Panel -->
        <LinearLayout
            android:id="@+id/widget_baking_status_panel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/widget_baking_details"
            android:gravity="end">

            <TextView
                android:id="@+id/widget_scale_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCALE: TARE"
                android:textColor="#8B5E3C"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_timer_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timer: Ready"
                android:textColor="#8B5E3C"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Action Buttons at bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentBottom="true"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/widget_btn_recipe"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="NEXT"
                android:textColor="#4A3728"
                android:background="#114A3728"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_btn_chef"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="CHEF"
                android:textColor="#4A3728"
                android:background="#114A3728"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_btn_timer"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="TIMER"
                android:textColor="#8B5E3C"
                android:background="#118B5E3C"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>


    </RelativeLayout>

</FrameLayout>
